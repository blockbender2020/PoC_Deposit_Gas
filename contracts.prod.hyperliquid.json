{
  "collateralToken": "0xb88339CB7199b77E23DB6E890353E22632Ba630f",
  "context": {
    "affiliateAddress": "0xBcB033C9154401fA000a1Ae60843f79f45741b7c",
    "symmioAddress": "0x57331038c21982116EE9b0906E4a5c5cB52dcE2e",
    "subAccountIsolationType": 3,
    "subAccountMetadata": "0x",
    "subAccountSingleVAMode": false,
    "subAccountNamePrefix": "gasless-"
